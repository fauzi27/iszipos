<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.IsziPos" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">?attr/colorBgCard</item>

        <item name="colorBgRoot">@color/light_bg_root</item>
        <item name="colorBgCard">@color/light_bg_card</item>
        <item name="colorTextMain">@color/light_text_main</item>
        <item name="colorTextSub">@color/light_text_sub</item>
        <item name="colorBorder">@color/light_border</item>
    </style>

    <style name="Theme.IsziPos.Brand" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#EA580C</item>
        <item name="android:statusBarColor">?attr/colorBgCard</item>

        <item name="colorBgRoot">@color/brand_bg_root</item>
        <item name="colorBgCard">@color/brand_bg_card</item>
        <item name="colorTextMain">@color/brand_text_main</item>
        <item name="colorTextSub">@color/brand_text_sub</item>
        <item name="colorBorder">@color/brand_border</item>
    </style>
</resources>
