<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvShopName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ISZI POS"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/tvShopAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Memuat lokasi..."
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/tvRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_badge_kasir"
            android:text="Kasir: -"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1D4ED8"
            android:visibility="gone"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintBottom_toTopOf="@id/statusContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:gravity="center_horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCashier"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="12dp"
                android:text="Mulai Jualan\nBuka Kasir &amp; Keranjang"
                android:textAllCaps="false"
                app:cornerRadius="16dp"
                app:backgroundTint="#2563EB"
                app:icon="@android:drawable/ic_menu_add" 
                app:iconSize="32dp"
                app:iconGravity="textStart"
                app:iconPadding="16dp"/>
                
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReport"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Laporan"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#9333EA"
                    app:iconGravity="top"
                    app:icon="@android:drawable/ic_menu_sort_by_size"/>
                    
                 <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTheme"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Tema UI"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#F59E0B"
                    app:iconGravity="top"
                    app:icon="@android:drawable/ic_menu_gallery"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStock"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Stok Barang"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#4F46E5"
                    app:iconGravity="top"
                    app:icon="@android:drawable/ic_menu_view"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTable"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Buku Besar"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#059669"
                    app:iconGravity="top"
                    app:icon="@android:drawable/ic_menu_agenda"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdmin"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Kelola Menu"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#EA580C"
                    app:iconGravity="top"
                    app:icon="@android:drawable/ic_menu_manage"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettings"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="Pengaturan"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#4B5563"
                    app:iconGravity="top"
                    app:icon="@android:drawable/ic_menu_preferences"/>

            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Tutup Shift (Logout)"
                android:textColor="#EF4444"
                app:strokeColor="#EF4444"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="@drawable/bg_status_online"
            android:text="● Sistem Cloud Online"
            android:textColor="#16A34A"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
