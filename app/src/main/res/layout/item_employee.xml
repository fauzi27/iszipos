<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/colorBgRoot"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorBorder"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvEmpName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Karyawan"
                    android:textColor="?attr/colorTextMain"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvEmpEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@sahabatusahamu.com"
                    android:textColor="?attr/colorTextSub"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnDeleteEmp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_button"
                android:backgroundTint="#7F1D1D"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#FCA5A5"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ketuk untuk On/Off Akses Menu:"
            android:textColor="?attr/colorTextSub"
            android:textSize="10sp"
            android:textStyle="italic"
            android:layout_marginBottom="8dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignBounds">

            <CheckBox android:id="@+id/chkAccessCashier" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mesin Kasir" android:textColor="?attr/colorTextMain" android:buttonTint="#10B981" android:layout_marginEnd="16dp"/>
            <CheckBox android:id="@+id/chkAccessCalculator" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kalkulator" android:textColor="?attr/colorTextMain" android:buttonTint="#10B981"/>
            <CheckBox android:id="@+id/chkAccessReport" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Laporan" android:textColor="?attr/colorTextMain" android:buttonTint="#10B981" android:layout_marginEnd="16dp"/>
            <CheckBox android:id="@+id/chkAccessStock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stok Barang" android:textColor="?attr/colorTextMain" android:buttonTint="#10B981"/>
            <CheckBox android:id="@+id/chkAccessTable" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tabel Rekap" android:textColor="?attr/colorTextMain" android:buttonTint="#10B981" android:layout_marginEnd="16dp"/>
            <CheckBox android:id="@+id/chkAccessMenu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kelola Menu" android:textColor="?attr/colorTextMain" android:buttonTint="#10B981"/>
            <CheckBox android:id="@+id/chkAccessSettings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pengaturan" android:textColor="?attr/colorTextMain" android:buttonTint="#10B981" android:layout_marginEnd="16dp"/>

        </GridLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
