<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="4dp"
        app:cardElevation="10dp"
        android:layout_marginBottom="16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="380dp"
            android:fadeScrollbars="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvReceiptShopName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NAMA TOKO"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:typeface="monospace"/>

                <TextView
                    android:id="@+id/tvReceiptAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alamat Toko"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:gravity="center"
                    android:typeface="monospace"
                    android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="--------------------------------" android:textColor="#000000" android:gravity="center" android:typeface="monospace" android:maxLines="1"/>

                <TextView android:id="@+id/tvReceiptDate" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tgl  : -" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>
                <TextView android:id="@+id/tvReceiptInvoice" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="No   : -" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>
                <TextView android:id="@+id/tvReceiptOperator" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Kasir: -" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>
                <TextView android:id="@+id/tvReceiptBuyer" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Plgn : Umum" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="--------------------------------" android:textColor="#000000" android:gravity="center" android:typeface="monospace" android:maxLines="1"/>

                <LinearLayout
                    android:id="@+id/containerReceiptItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="--------------------------------" android:textColor="#000000" android:gravity="center" android:typeface="monospace" android:maxLines="1"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Item" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>
                    <TextView android:id="@+id/tvReceiptTotalItem" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TOTAL" android:textColor="#000000" android:textStyle="bold" android:textSize="14sp" android:typeface="monospace"/>
                    <TextView android:id="@+id/tvReceiptTotal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Rp 0" android:textColor="#000000" android:textStyle="bold" android:textSize="14sp" android:typeface="monospace" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginTop="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Metode" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>
                    <TextView android:id="@+id/tvReceiptMethod" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TUNAI" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dibayar" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>
                    <TextView android:id="@+id/tvReceiptPaid" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Rp 0" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/rowReceiptChange" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Kembali" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace"/>
                    <TextView android:id="@+id/tvReceiptChange" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Rp 0" android:textColor="#000000" android:textSize="12sp" android:typeface="monospace" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/rowReceiptRemaining" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sisa Hutang" android:textColor="#DC2626" android:textStyle="bold" android:textSize="12sp" android:typeface="monospace"/>
                    <TextView android:id="@+id/tvReceiptRemaining" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Rp 0" android:textColor="#DC2626" android:textStyle="bold" android:textSize="12sp" android:typeface="monospace" android:gravity="end"/>
                </LinearLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="--------------------------------" android:textColor="#000000" android:gravity="center" android:typeface="monospace" android:maxLines="1" android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvReceiptFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Terima Kasih"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:typeface="monospace"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:id="@+id/containerWatermark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View android:layout_width="100dp" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Powered by ISZI POS Cloud" android:textColor="#9CA3AF" android:textSize="10sp" android:typeface="monospace"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aplikasi Kasir Gratis &amp; Mudah" android:textColor="#9CA3AF" android:textSize="10sp" android:typeface="monospace"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReceiptClose"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Tutup"
            android:textColor="#FFFFFF"
            app:backgroundTint="#475569"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReceiptPrint"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Print Struk"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2563EB"
            app:cornerRadius="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReceiptWA"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Kirim WA"
            android:textColor="#10B981"
            app:strokeColor="#10B981"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReceiptPDF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Simpan PDF"
            android:textColor="#F59E0B"
            app:strokeColor="#F59E0B"
            app:cornerRadius="8dp"/>
    </LinearLayout>

</LinearLayout>
