<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_badge_kasir"
    android:backgroundTint="#1E293B"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvCartItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama Item"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>
        <TextView
            android:id="@+id/tvCartItemSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 x Rp 0"
            android:textColor="#9CA3AF"
            android:textSize="12sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">
        <TextView
            android:id="@+id/tvCartItemTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
            
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_circle_button"
            android:backgroundTint="#334155"
            android:gravity="center_vertical">
            <TextView android:id="@+id/btnQtyMin" android:layout_width="32dp" android:layout_height="28dp" android:text="-" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:gravity="center"/>
            <TextView android:id="@+id/tvCartQty" android:layout_width="30dp" android:layout_height="wrap_content" android:text="1" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
            <TextView android:id="@+id/btnQtyPlus" android:layout_width="32dp" android:layout_height="28dp" android:text="+" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
