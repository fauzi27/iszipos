<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#1E293B">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_dialog_map"
            app:tint="#FFFFFF"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ISZI Command Center"
                android:textColor="#3B82F6"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvAdminEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="God Mode: admin@iszi.com"
                android:textColor="#9CA3AF"
                android:textSize="12sp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnLogoutAdmin"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_lock_power_off"
            app:tint="#EF4444"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:padding="12dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_badge_kasir"
                        android:backgroundTint="#1E293B"
                        android:padding="16dp"
                        android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Toko" android:textColor="#9CA3AF" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvMetricToko" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_badge_kasir"
                        android:backgroundTint="#1E293B"
                        android:padding="16dp"
                        android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Karyawan" android:textColor="#9CA3AF" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvMetricStaff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_badge_kasir"
                        android:backgroundTint="#1E293B"
                        android:padding="16dp"
                        android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Beban Server" android:textColor="#9CA3AF" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvMetricDocs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Docs" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Direktori Pelanggan"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <ImageButton
                    android:id="@+id/btnRefreshAdmin"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="#334155"
                    android:src="@android:drawable/stat_notify_sync"
                    app:tint="#CBD5E1"/>
            </LinearLayout>

            <EditText
                android:id="@+id/inputSearchClient"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_circle_button"
                android:backgroundTint="#1E293B"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"
                android:paddingHorizontal="16dp"
                android:hint="Cari nama toko atau email..."/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="12dp"
                android:paddingBottom="40dp"
                android:clipToPadding="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
