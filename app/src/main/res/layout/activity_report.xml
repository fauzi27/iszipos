<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#1E293B">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Laporan Penjualan"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btnSyncCloud"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_button"
            android:backgroundTint="#1D4ED8"
            android:src="@android:drawable/stat_notify_sync"
            app:tint="#FFFFFF"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="12dp"
                android:background="#1E293B">
                
                <ImageButton
                    android:id="@+id/btnDatePrev"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#9CA3AF"/>
                    
                <TextView
                    android:id="@+id/tvDateDisplay"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="Hari Ini"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
                    
                <ImageButton
                    android:id="@+id/btnDateNext"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="#9CA3AF"/>
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="12dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_badge_kasir"
                    android:backgroundTint="#1E293B"
                    android:padding="12dp"
                    android:layout_margin="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Omzet Kotor" android:textColor="#9CA3AF" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvTotalOmzet" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_badge_kasir"
                    android:backgroundTint="#064E3B"
                    android:padding="12dp"
                    android:layout_margin="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Laba Bersih" android:textColor="#34D399" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvTotalLaba" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="#10B981" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_badge_kasir"
                    android:backgroundTint="#1E293B"
                    android:padding="12dp"
                    android:layout_margin="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tunai" android:textColor="#9CA3AF" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvTotalTunai" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_badge_kasir"
                    android:backgroundTint="#7F1D1D"
                    android:padding="12dp"
                    android:layout_margin="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sisa Hutang" android:textColor="#FCA5A5" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvTotalHutang" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="#EF4444" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>
            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportExcel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Excel"
                    app:backgroundTint="#166534"
                    app:icon="@android:drawable/ic_menu_save"
                    android:layout_marginEnd="4dp"/>
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportPdf"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PDF"
                    app:backgroundTint="#991B1B"
                    app:icon="@android:drawable/ic_menu_view"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <EditText
                android:id="@+id/inputSearchTx"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_circle_button"
                android:backgroundTint="#1E293B"
                android:textColor="#FFFFFF"
                android:textColorHint="#9CA3AF"
                android:paddingHorizontal="16dp"
                android:hint="Cari nama atau metode..."/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="8dp"/>
                
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
