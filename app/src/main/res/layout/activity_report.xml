<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBgRoot">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/colorBgCard">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="?attr/colorTextMain"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Laporan"
            android:textColor="?attr/colorTextMain"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnExportPdf"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#6366F1"
            android:layout_marginEnd="8dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#FFFFFF"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnExportExcel"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#10B981">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_save"
                app:tint="#FFFFFF"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_modern"
                android:backgroundTint="?attr/colorBgCard"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="16dp">
                
                <ImageButton
                    android:id="@+id/btnDatePrev"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="#3B82F6"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#FFFFFF"/>
                    
                <TextView
                    android:id="@+id/tvDateDisplay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="24 Mar 2026"
                    android:textColor="?attr/colorTextMain"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
                    
                <ImageButton
                    android:id="@+id/btnDateNext"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="#3B82F6"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="#FFFFFF"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_modern"
                android:backgroundTint="?attr/colorBgCard"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="12dp">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterDaily"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Harian"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            app:backgroundTint="#3B82F6"
                            app:cornerRadius="20dp"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterWeekly"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Mingguan"
                            android:textColor="?attr/colorTextSub"
                            android:textSize="12sp"
                            app:backgroundTint="?attr/colorBgRoot"
                            app:cornerRadius="20dp"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterMonthly"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Bulanan"
                            android:textColor="?attr/colorTextSub"
                            android:textSize="12sp"
                            app:backgroundTint="?attr/colorBgRoot"
                            app:cornerRadius="20dp"
                            android:layout_marginEnd="8dp"/>
                            
                        <ImageButton
                            android:id="@+id/btnSyncCloud"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_button"
                            android:backgroundTint="#3B82F6"
                            android:src="@android:drawable/stat_notify_sync"
                            app:tint="#FFFFFF"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <EditText
                    android:id="@+id/inputSearchTx"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="?attr/colorBgRoot"
                    android:textColor="?attr/colorTextMain"
                    android:textColorHint="?attr/colorTextSub"
                    android:paddingHorizontal="16dp"
                    android:hint="Cari pelanggan, metode..."/>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_modern"
                android:backgroundTint="?attr/colorBgCard"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:clipToPadding="false">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginEnd="-10dp"
                    android:layout_marginTop="-10dp"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="?attr/colorBorder"
                    android:alpha="0.3"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvLabelOmzet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OMZET KOTOR"
                        android:textColor="?attr/colorTextSub"
                        android:textSize="10sp"/>
                    <TextView
                        android:id="@+id/tvTotalOmzet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="?attr/colorTextMain"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorBorder" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Masuk Tunai" android:textColor="?attr/colorTextSub" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvTotalTunai" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="?attr/colorTextMain" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Masuk QRIS" android:textColor="?attr/colorTextSub" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvTotalQRIS" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="?attr/colorTextMain" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="16dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sisa Hutang" android:textColor="#FCA5A5" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvTotalHutang" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="#EF4444" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nota Sukses" android:textColor="?attr/colorTextSub" android:textSize="12sp"/>
                            <TextView android:id="@+id/tvTotalNota" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Nota" android:textColor="?attr/colorTextMain" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorBorder" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Laba / Keuntungan Bersih" android:textColor="?attr/colorTextSub" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvTotalLaba" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textColor="#10B981" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
                
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
