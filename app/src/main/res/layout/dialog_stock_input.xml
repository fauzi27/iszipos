<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_badge_kasir"
    android:backgroundTint="#1E293B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tvModalTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Update Stok: Menu X"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>
        <ImageButton
            android:id="@+id/btnCloseModal"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#9CA3AF"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_circle_button"
        android:backgroundTint="#0F172A"
        android:padding="4dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeAdd"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="+ Tambah"
            android:textSize="10sp"
            app:backgroundTint="#22C55E"
            app:cornerRadius="6dp"
            android:layout_marginEnd="2dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeSub"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="- Kurang"
            android:textSize="10sp"
            app:backgroundTint="#0F172A"
            android:textColor="#6B7280"
            app:cornerRadius="6dp"
            android:layout_marginHorizontal="2dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeSet"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="= Set Total"
            android:textSize="10sp"
            app:backgroundTint="#0F172A"
            android:textColor="#6B7280"
            app:cornerRadius="6dp"
            android:layout_marginStart="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_circle_button"
        android:backgroundTint="#1E3A8A"
        android:padding="12dp"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STOK AWAL" android:textColor="#93C5FD" android:textSize="10sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvPreviewAwal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#BFDBFE" android:textSize="20sp" android:textStyle="bold"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="->" android:textColor="#60A5FA" android:textSize="20sp" android:textStyle="bold" android:layout_marginHorizontal="24dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HASIL AKHIR" android:textColor="#93C5FD" android:textSize="10sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvPreviewAkhir" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/inputStockNumber"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_circle_button"
        android:backgroundTint="#0F172A"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="center"
        android:inputType="number"
        android:hint="0"
        android:textColorHint="#475569"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveStockModal"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Simpan Perubahan"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#4F46E5"
        app:icon="@android:drawable/ic_menu_save"
        app:iconGravity="textStart"
        app:cornerRadius="12dp"/>
</LinearLayout>
